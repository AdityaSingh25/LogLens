# Copy this file to infra/.env and fill in real values for production
# For local dev, defaults in docker-compose.yml are sufficient

POSTGRES_DB=loglens
POSTGRES_USER=loglens
POSTGRES_PASSWORD=loglens

KAFKA_BROKERS=localhost:9092

ES_URL=http://localhost:9200

QDRANT_URL=http://localhost:6333

REDIS_URL=redis://localhost:6379

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Auth service
JWT_PRIVATE_KEY=        # RSA private key PEM (generated on first run in dev mode)
JWT_PUBLIC_KEY=         # RSA public key PEM

# Embedding & query services
OPENAI_API_KEY=         # sk-...

# Notification service
SLACK_BOT_TOKEN=        # xoxb-...
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
